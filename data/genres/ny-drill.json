{
  "$schema": "../schema/artist-style.schema.json",
  "id": "ny-drill",
  "type": "genre",
  "name": "NY Drill",
  "aliases": ["brooklyn drill", "ny/bk drill"],
  "tier": "standard",
  "extends": ["_defaults"],
  "era": "2019–present",
  "genres": ["rap", "drill"],
  "confidence": "high",
  "sources": ["style-research ch.1 §2 Drill (NY/Brooklyn)"],
  "notes": "UK grammar exported to Brooklyn via 808Melo and AXL: the same sliding 808 and tresillo kick, but quantized harder, with a bigger reverb snare and longer, more prominent slides. Its signature two-bar snare form puts the hit on 3 in the first bar and on 4 in the second.",

  "session": {
    "bpm": { "min": 138, "max": 150, "mode": 142 },
    "halfTime": true,
    "keys": { "values": ["Cm", "Dm", "Am", "Fm"], "weights": [3, 3, 2, 2] },
    "scales": { "values": ["natural_minor", "phrygian", "harmonic_minor"], "weights": [4, 3, 2] },
    "swing": { "grid": "16th", "amount": 0.52 },
    "humanize": {
      "quantizeStrength": 0.95,
      "velocityVar": 0.1,
      "timingJitterMs": { "kick": 1, "snare": 2, "clap": 2, "closedHat": 2, "bass808": 1 }
    }
  },

  "drums": {
    "kick": {
      "densityPerBar": [3, 5],
      "anchors": ["1"],
      "offbeat8thShare": 0.35,
      "syncopation": 0.65,
      "tresilloBias": 0.55,
      "avoidPreSnareGap": "8th",
      "lockTo808": 0.7,
      "fourBarGrammar": [["1", "2&", "4"], ["1&", "3"]]
    },
    "snare": {
      "placement": "drill_3_4",
      "reverb": "large",
      "ghost": { "prob": 0.5, "pos": ["4&"], "vel": [0.4, 0.5] },
      "offGridMs": [0, 2]
    },
    "hihat": {
      "base": "tresillo",
      "tresilloGrouping": [3, 3, 2],
      "fillDensity": 0.55,
      "velocities": { "main": [0.9, 1.0], "ghost": [0.4, 0.6] },
      "rolls": {
        "vocab": { "values": ["16", "16T", "32"], "weights": [4, 3, 2] },
        "positions": ["phrase_end", "pre_snare", "bar_4"],
        "freqPerBar": 0.5,
        "velocityRamp": true,
        "burstNotes": [3, 3]
      },
      "openHat": { "prob": 0.35, "pos": ["2&"], "perBar": [1, 1] },
      "pitchBendProb": 0.05
    },
    "percs": { "lanes": ["rim"], "densityPerBar": [1, 2], "placement": "offbeat" },
    "fills": { "smallEveryBars": 2, "bigEveryBars": 8, "snareRollLadder": false },
    "bass808": {
      "role": "counter_riff",
      "sustain": "legato",
      "monoCutSelf": true,
      "portamentoMs": [30, 45],
      "slidesPer4Bars": [2, 3],
      "slideProb": 0.7,
      "slideIntervals": { "values": ["P5", "P8", "m7"], "weights": [3, 3, 2] },
      "slidePositions": ["phrase_end", "bar_4"],
      "longDownGlideProb": 0.4,
      "muteUnderSnare": true,
      "melodicallyIndependent": true,
      "register": [24, 36],
      "distortion": "medium"
    }
  }
}
