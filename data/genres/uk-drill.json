{
  "$schema": "../schema/artist-style.schema.json",
  "id": "uk-drill",
  "type": "genre",
  "name": "UK Drill",
  "aliases": ["uk drill", "london drill"],
  "tier": "standard",
  "extends": ["_defaults"],
  "era": "2015–present",
  "genres": ["rap", "drill"],
  "confidence": "high",
  "sources": [
    "style-research ch.1 §2 Drill (UK)",
    "style-research ch.2 §4 Drill melodies & sliding 808s"
  ],
  "notes": "The 808 is the genre engine, not the bass: it carries its own counter-riff in 5ths, b7s and octaves rather than doubling the roots, and it mutes under every snare. Kicks lean hard on offbeat 8ths — roughly 40% land off the grid — and hats alternate straight-16th bars against triplet-grouped ones.",

  "session": {
    "bpm": { "min": 138, "max": 150, "mode": 141 },
    "halfTime": true,
    "keys": { "values": ["Cm", "Dm", "Am", "Gm", "Fm"], "weights": [3, 3, 3, 1, 1] },
    "scales": {
      "values": ["natural_minor", "harmonic_minor", "phrygian"],
      "weights": [4, 2, 3]
    },
    "swing": { "grid": "16th", "amount": 0.55 },
    "humanize": {
      "quantizeStrength": 0.88,
      "velocityVar": 0.14,
      "timingJitterMs": { "kick": 1, "snare": 4, "clap": 4, "closedHat": 3, "perc": 4, "bass808": 1 }
    }
  },

  "drums": {
    "kick": {
      "densityPerBar": [3, 5],
      "anchors": ["1"],
      "offbeat8thShare": 0.4,
      "syncopation": 0.7,
      "tresilloBias": 0.6,
      "avoidPreSnareGap": "8th",
      "lockTo808": 0.6,
      "fourBarGrammar": [["1", "2&", "4"], ["1&", "3"]]
    },
    "snare": {
      "placement": "halftime_3",
      "ghost": { "prob": 0.7, "pos": ["4&"], "vel": [0.4, 0.5] },
      "offGridMs": [2, 6],
      "clusterProb": 0.1
    },
    "hihat": {
      "base": "tresillo",
      "tresilloGrouping": [3, 3, 2],
      "fillDensity": 0.6,
      "velocities": { "main": [0.9, 1.0], "ghost": [0.4, 0.6] },
      "tripletBarAlternationProb": 0.5,
      "rolls": {
        "vocab": { "values": ["16", "16T", "32"], "weights": [4, 4, 2] },
        "positions": ["phrase_end", "pre_snare", "bar_4"],
        "freqPerBar": 0.6,
        "velocityRamp": true,
        "burstNotes": [3, 3]
      },
      "openHat": { "prob": 0.4, "pos": ["2&"], "perBar": [1, 1] },
      "pitchBendProb": 0.05
    },
    "percs": {
      "lanes": ["rim", "woodblock"],
      "densityPerBar": [1, 3],
      "placement": "offbeat",
      "gainOffsetDb": -12
    },
    "fills": { "smallEveryBars": 2, "bigEveryBars": 8, "snareRollLadder": false },
    "bass808": {
      "role": "counter_riff",
      "sustain": "legato",
      "monoCutSelf": true,
      "portamentoMs": [20, 35],
      "slidesPer4Bars": [2, 3],
      "slideProb": 0.6,
      "slideIntervals": { "values": ["P5", "m7", "P8", "M2"], "weights": [3, 3, 2, 2] },
      "slidePositions": ["phrase_end", "bar_4"],
      "upwardWhoopProb": 0.3,
      "longDownGlideProb": 0.35,
      "muteUnderSnare": true,
      "melodicallyIndependent": true,
      "register": [24, 28],
      "distortion": "heavy",
      "distortionWet": [0.2, 0.4]
    }
  },

  "chords": {
    "progressionFamilies": [
      { "roman": ["i", "v", "VI"], "weight": 3 },
      { "roman": ["i", "VII", "VI"], "weight": 3 },
      { "roman": ["i", "iv", "VII", "III"], "weight": 2 },
      { "roman": ["i", "bII", "i"], "weight": 2 },
      { "roman": ["i", "v", "iv", "VII"], "weight": 2 },
      { "roman": ["i", "VI"], "weight": 2 }
    ],
    "maxChords": 4,
    "extensions": { "triad": 0.75, "seventh": 0.2, "ninth": 0.05 },
    "voicing": { "style": "close", "register": [48, 72], "topVoiceStepwise": true, "lowPassed": true },
    "harmonicRhythm": { "values": ["2_bars_per_chord", "1_per_bar"], "weights": [3, 2] },
    "susOrDimProb": 0.2,
    "dissonanceBudget": { "m2": 0.1, "tritone": 0.05 }
  },

  "melody": {
    "register": [48, 72],
    "phraseBars": { "values": [2, 4], "weights": [3, 2] },
    "densityPerBar": [2, 6],
    "structure": "riff_loop",
    "twoBarCellRepeat": true,
    "intervals": { "step": 0.6, "third": 0.25, "leap": 0.15 },
    "contour": { "riff": 0.5, "descend": 0.35, "arch": 0.15 },
    "chordToneBias": 0.6,
    "halfStepDissonance": 0.15,
    "monophonicBias": 0.8,
    "mirrorSnareDisplacement": true,
    "endVariation": true,
    "octaveJumpProb": 0.1,
    "timbreHint": "detuned_piano"
  },

  "countermelody": {
    "registerOffset": -12,
    "densityRatio": 0.35,
    "fillGapsOnly": true,
    "styles": { "values": ["answer_lick", "sustain_pad"], "weights": [2, 3] }
  },

  "bassline": {
    "followRootsProb": 0.45,
    "rhythm": "independent_riff",
    "register": [24, 28],
    "glideProb": 0.6,
    "passingTones": ["P5", "m7", "P8"],
    "anticipationProb": 0.4
  },

  "arrangement": {
    "sectionBars": { "intro": [4, 8], "verse": 16, "hook": 8, "bridge": [4, 8], "outro": 4 },
    "melodic808SlideAtLoopEnd": true,
    "transitions": { "fillBeforeSection": true, "dropOutBeats": { "prob": 0.5, "beats": 2 }, "switchUpProb": 0.2 }
  },

  "kit": { "preview": "drill-default" }
}
